<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Adverse_Action_Code_Required</fullName>
    <active>true</active>
    <description>Requires an adverse action code for denied or counter-offer outcomes.</description>
    <errorConditionFormula>
        AND(
            OR(
                ISPICKVAL(Decision__c, "Deny"),
                ISPICKVAL(Decision__c, "Counter-offer")
            ),
            ISBLANK(TEXT(Adverse_Action_Code__c))
        )
    </errorConditionFormula>
    <errorDisplayField>Adverse_Action_Code__c</errorDisplayField>
    <errorMessage>Adverse Action Code is required for ECOA adverse action decisions.</errorMessage>
</ValidationRule>
