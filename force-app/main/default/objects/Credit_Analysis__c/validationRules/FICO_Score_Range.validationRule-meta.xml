<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>FICO_Score_Range</fullName>
    <active>true</active>
    <description>Keeps FICO score inside the standard 300 to 850 range.</description>
    <errorConditionFormula>
        AND(
            NOT(ISBLANK(FICO_Score__c)),
            OR(
                FICO_Score__c &lt; 300,
                FICO_Score__c &gt; 850
            )
        )
    </errorConditionFormula>
    <errorDisplayField>FICO_Score__c</errorDisplayField>
    <errorMessage>FICO Score must be between 300 and 850.</errorMessage>
</ValidationRule>
