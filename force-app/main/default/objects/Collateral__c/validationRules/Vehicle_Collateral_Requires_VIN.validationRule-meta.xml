<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Vehicle_Collateral_Requires_VIN</fullName>
    <active>true</active>
    <description>Requires a 17 character VIN for vehicle collateral.</description>
    <errorConditionFormula>
        AND(
            ISPICKVAL(Collateral_Type__c, "Vehicle"),
            LEN(VIN__c) &lt;&gt; 17
        )
    </errorConditionFormula>
    <errorDisplayField>VIN__c</errorDisplayField>
    <errorMessage>Vehicle collateral requires a valid 17 character VIN.</errorMessage>
</ValidationRule>
