<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>FDCPA_Opt_Out_Assigned_Agent</fullName>
    <active>true</active>
    <description>Prevents outreach assignment when FDCPA opt-out is active.</description>
    <errorConditionFormula>
        AND(
            FDCPA_Opt_Out__c,
            NOT(ISBLANK(Assigned_Agent__c))
        )
    </errorConditionFormula>
    <errorDisplayField>Assigned_Agent__c</errorDisplayField>
    <errorMessage>Assigned Agent must remain blank while FDCPA opt-out is active.</errorMessage>
</ValidationRule>
