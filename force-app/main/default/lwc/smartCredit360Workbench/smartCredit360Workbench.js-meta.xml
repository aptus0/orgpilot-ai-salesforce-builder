<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>SmartCredit 360 Workbench</masterLabel>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage,lightning__AppPage,lightning__HomePage,lightning__FlowScreen">
            <property name="applicantName" type="String" label="Applicant Name" />
            <property name="decision" type="String" label="Decision" />
            <property name="dtiRatio" type="String" label="DTI Ratio" />
            <property name="ltvRatio" type="String" label="LTV Ratio" />
            <property name="ficoScore" type="Integer" label="FICO Score" />
            <property name="creditPullConsent" type="Boolean" label="Credit Pull Consent" />
            <property name="cipVerified" type="Boolean" label="CIP Verified" />
            <property name="ofacCleared" type="Boolean" label="OFAC Cleared" />
            <property name="reportReference" type="String" label="Report Reference" />
            <property name="reportSummary" type="String" label="Report Summary" />
            <property name="errorLogs" type="String" label="Error Logs" description="Line format: SEVERITY|AREA|MESSAGE" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
