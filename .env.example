# Temas RE Custom Object Auto
# Copy to .env.local

# Optional: OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Salesforce AI / Einstein / Agent adapter endpoint
# Bu proje generic endpoint adapter kullanır; kendi Salesforce AI gateway'in JSON schema döndürmelidir.
SALESFORCE_AI_ENDPOINT=
SALESFORCE_AI_API_KEY=

# Optional: ALBERT / external AI adapter endpoint
ALBERT_AI_ENDPOINT=
ALBERT_AI_API_KEY=

# Optional: kendi Scala LLM servisimiz
SCALA_LLM_ENDPOINT=http://localhost:9090/generate-schema
SCALA_LLM_API_KEY=local-dev-token

# Salesforce Metadata API deploy
# Developer Edition için login.salesforce.com, Sandbox için test.salesforce.com kullan.
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_TARGET_ORG=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_API_VERSION=60.0
